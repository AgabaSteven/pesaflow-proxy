# ── D Gateway proxy — environment variables ────────────────────────────────
# Copy this file to ".env" for local dev, OR set these in your Vercel project
# under Settings → Environment Variables. NEVER commit real values.

# REQUIRED — your D Gateway secret API key (Dashboard → Settings / API access).
# Sent as the "X-Api-Key" header to https://dgatewayapi.desispay.com.
DGATEWAY_API_KEY=

# REQUIRED for secure webhooks — the Webhook Secret from your D Gateway
# Dashboard → Settings. Used to verify the HMAC-SHA256 signature on incoming
# /api/webhook calls. Without it, webhook signatures cannot be validated.
DGATEWAY_WEBHOOK_SECRET=

# OPTIONAL — lock CORS to your published Framer site, e.g. https://yourstore.com
# Leave unset (or "*") to allow any origin while testing.
ALLOWED_ORIGIN=*

# ── Order storage (Upstash Redis / Vercel KV) ──────────────────────────────
# These are injected AUTOMATICALLY when you attach an Upstash/KV store to the
# Vercel project (Storage tab) — you normally do NOT set them by hand.
# The proxy still runs without a store (payments work), but orders won't be
# saved for cross-device lookup by OrderTracker / the plugin's Orders tab.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Plain Upstash databases use these names instead — either pair works.)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
